{
  "name": "claritystructures-webapp",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:domain": "vitest run packages/domain",
    "test:integration": "vitest run tests/integration",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint:fix": "eslint --fix .",
    "start": "pnpm --filter @claritystructures/web run start",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate:idempotency": "pnpm exec prisma validate --config prisma.config.ts && pnpm db:generate && pnpm exec vitest run packages/domain/src/__tests__/idempotency.test.ts packages/domain/src/__tests__/transfer-packet.test.ts apps/web/src/__tests__/application/use-cases/generate-transfer-packet.usecase.test.ts",
    "validate:core": "pnpm validate:idempotency && pnpm typecheck",
    "validate:full": "pnpm validate:core && pnpm lint && pnpm build",
    "db:migrate:dev:safe": "node scripts/guard-prisma-datasource.mjs && prisma migrate dev --config prisma.config.ts",
    "db:migrate:status": "prisma migrate status --config prisma.config.ts"
  },
  "devDependencies": {
    "@claritystructures/domain": "workspace:*",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^7.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.4",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "dotenv": "^16.4.7",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prisma": "^7.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.0",
      "hono": "4.12.21",
      "minimatch": "10.2.3",
      "protobufjs": "7.5.8",
      "@protobufjs/utf8": "1.1.1",
      "dompurify": "3.4.0",
      "@hono/node-server": "1.19.13",
      "undici": "7.24.0",
      "rollup": "4.59.0",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "brace-expansion": "5.0.6",
      "postcss": "8.5.10",
      "vite": "7.3.2",
      "uuid": "11.1.1",
      "yaml": "2.8.3",
      "flatted": "3.4.2",
      "ajv": "6.14.0",
      "defu": "6.1.5",
      "effect": "3.20.0",
      "esbuild": "0.28.1"
    }
  },
  "dependencies": {
    "@sentry/nextjs": "^10.38.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "isomorphic-dompurify": "3.0.0-rc.2",
    "next": "16.2.6",
    "resend": "^6.9.2",
    "zod": "^4.3.6"
  },
  "license": "UNLICENSED"
}
